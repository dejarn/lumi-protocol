{
  "name": "lumi-protocol",
  "version": "1.0.0",
  "description": "Binary protocol library for lumi LED strip controllers (Node.js / TypeScript)",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "prepare": "tsc",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@types/node": "^20.19.41",
    "mqtt": "^5.0.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.8"
  }
}
